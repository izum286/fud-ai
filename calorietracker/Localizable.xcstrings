    "At most 2 macros can be pinned at a time. Unpin another macro first (tap its lock icon)." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكن تثبيت 2 من العناصر الكبرى كحد أقصى في وقت واحد. قم بإلغاء تثبيت عنصر آخر أولاً (اضغط على أيقونة القفل)."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Eyni zamanda ən çox 2 makro sabitlənə bilər. Əvvəlcə başqa bir makronu çıxarın (kilid işarəsinə toxunun)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Es können maximal 2 Makros gleichzeitig angeheftet werden. Löse zuerst ein anderes Makro (tippe auf das Schloss-Symbol)."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "At most 2 macros can be pinned at a time. Unpin another macro first (tap its lock icon)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se pueden fijar como máximo 2 macros a la vez. Desfija otro macro primero (toca su icono de candado)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous pouvez épingler au maximum 2 macros à la fois. Détachez d'abord une autre macro (appuyez sur son icône de verrou)."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "एक समय में अधिकतम 2 मैक्रो पिन किए जा सकते हैं। पहले किसी अन्य मैक्रो को अनपिन करें (उसके लॉक आइकन पर टैप करें)।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "È possibile fissare al massimo 2 macro alla volta. Sblocca prima un'altra macro (tocca l'icona del lucchetto)."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一度に固定できるマクロは最大2つです。まず別のマクロの固定を解除してください（ロックアイコンをタップ）。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "한 번에 최대 2개의 매크로만 고정할 수 있습니다. 다른 매크로의 고정을 먼저 해제하세요 (자물쇠 아이콘 탭)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er kunnen maximaal 2 macro's tegelijk worden vastgezet. Maak eerst een andere macro los (tik op het slotje)."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No máximo 2 macros podem ser fixados por vez. Desafixe outro macro primeiro (toque no ícone de cadeado)."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se pot fixa cel mult 2 macronutrienți simultan. Elimină mai întâi fixarea altuia (atinge pictograma de lacăt)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Одновременно можно закрепить не более 2 макронутриентов. Сначала открепите другой (нажмите на значок замка)."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "一次最多只能固定 2 个宏量营养素。请先取消固定另一个（点按其锁定图标）。"
          }
        }
      }
    },
