    "Clear all messages and start fresh? This can't be undone." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "هل تريد مسح جميع الرسائل والبدء من جديد؟ لا يمكن التراجع عن هذا الإجراء."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bütün mesajları silib yenidən başlayaq? Bu əməliyyat geri qaytarıla bilməz."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alle Nachrichten löschen und neu beginnen? Das kann nicht rückgängig gemacht werden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clear all messages and start fresh? This can't be undone."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Borrar todos los mensajes y empezar de cero? Esta acción no se puede deshacer."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Effacer tous les messages et recommencer ? Cette action est irréversible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सभी संदेश मिटाकर नई शुरुआत करें? इसे पूर्ववत नहीं किया जा सकता।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cancellare tutti i messaggi e ricominciare? L'operazione è irreversibile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "すべてのメッセージを消去して最初からやり直しますか?この操作は取り消せません。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "모든 메시지를 지우고 새로 시작할까요? 이 작업은 되돌릴 수 없습니다."
