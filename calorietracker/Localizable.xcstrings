    "Notifications are disabled in system settings. Tap to open Settings." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "الإشعارات معطلة في إعدادات النظام. اضغط لفتح الإعدادات."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bildirişlər sistem parametrlərində söndürülüb. Parametrləri açmaq üçün toxunun."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mitteilungen sind in den Systemeinstellungen deaktiviert. Tippe, um Einstellungen zu öffnen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifications are disabled in system settings. Tap to open Settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las notificaciones están desactivadas en los ajustes del sistema. Toca para abrir Ajustes."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les notifications sont désactivées dans les réglages du système. Touchez pour ouvrir Réglages."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सिस्टम सेटिंग्स में सूचनाएँ बंद हैं। सेटिंग्स खोलने के लिए टैप करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le notifiche sono disattivate nelle impostazioni di sistema. Tocca per aprire Impostazioni."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "システム設定で通知がオフになっています。タップして設定を開いてください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "시스템 설정에서 알림이 비활성화되어 있습니다. 탭하여 설정을 여세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Meldingen zijn uitgeschakeld in de systeeminstellingen. Tik om Instellingen te openen."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
