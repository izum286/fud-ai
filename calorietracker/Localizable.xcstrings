    "Log at least 2 days of food and 2 weights to see your forecast." : {
      "extractionState" : "stale",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سجّل ما لا يقل عن يومين من الطعام ووزنين لرؤية توقعاتك."
          }
        },
        "az" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Proqnozunuzu görmək üçün ən azı 2 günlük yemək və 2 çəki qeyd edin."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Protokolliere mindestens 2 Tage Essen und 2 Gewichte, um deine Prognose zu sehen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Log at least 2 days of food and 2 weights to see your forecast."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra al menos 2 días de comida y 2 pesajes para ver tu previsión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Enregistrez au moins 2 jours de repas et 2 pesées pour voir votre prévision."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपना पूर्वानुमान देखने के लिए कम से कम 2 दिन का भोजन और 2 वज़न दर्ज करें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registra almeno 2 giorni di cibo e 2 pesate per vedere la tua previsione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "予測を表示するには、食事を2日分と体重を2回以上記録してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "예측을 보려면 최소 2일간의 식사와 2회의 체중을 기록하세요."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Log minstens 2 dagen voeding en 2 gewichten om je voorspelling te zien."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Registre pelo menos 2 dias de comida e 2 pesagens para ver sua previsão."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Înregistrează cel puțin 2 zile de mâncare și 2 cântăriri pentru a vedea prognoza."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Запишите минимум 2 дня еды и 2 измерения веса, чтобы увидеть прогноз."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "至少记录2天的饮食和2次体重,才能查看预测。"
          }
        }
      }
    },
